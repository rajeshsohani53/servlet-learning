<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://jakarta.ee/xml/ns/jakartaee" xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd" id="WebApp_ID" version="6.0">
  <display-name>TicketBooking_ServletFilter</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
  </welcome-file-list>
  <!-- ticket booking -->
  <servlet>
    <servlet-name>TicketBookingServlet</servlet-name>
    <servlet-class>com.rajesh.ticketbooking.TicketBookingServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>TicketBookingServlet</servlet-name>
  <url-pattern>/TicketBookingServlet</url-pattern>
  </servlet-mapping>
  
    <servlet>
    <servlet-name>DisplayTicket</servlet-name>
    <servlet-class>com.rajesh.ticketbooking.DisplayTicket</servlet-class>
  </servlet>
  <servlet-mapping>
  <servlet-name>DisplayTicket</servlet-name>
  <url-pattern>/DisplayTicket</url-pattern>
  </servlet-mapping>
  
  
  
</web-app>